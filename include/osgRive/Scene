#pragma once

#include <osgRive/Export>
#include <osgRive/TextureRenderer>

#include <osg/Geode>
#include <osg/Group>
#include <osg/Texture2D>

#include <string>

namespace osgRive
{

// A directly addable OSG node that renders one Rive .riv scene/artboard into
// an owned GL_RGBA8 texture and displays it on a default unit quad. The
// internal producer drawable, producer geode, textured display geometry,
// render-bin ordering, blend state, and ColorMask repair are owned here so
// callers can treat this like ordinary visible OSG content.
class OSGRIVE_EXPORT Scene : public osg::Group
{
public:
    Scene();
    Scene(const std::string& rivPath, unsigned int width, unsigned int height);
    Scene(const Scene& scene, const osg::CopyOp& copyop = osg::CopyOp::SHALLOW_COPY);

    META_Object(osgRive, Scene)

    void setDrawMode(DrawMode mode);
    DrawMode getDrawMode() const;

    // The texture Rive renders into. Valid immediately after construction;
    // contents become live after the first successful draw.
    osg::Texture2D* getTexture();
    const osg::Texture2D* getTexture() const;

    osg::Geode* getDisplayGeode();
    const osg::Geode* getDisplayGeode() const;

protected:
    ~Scene() override;

private:
    class RenderDrawable;

    void init(const std::string& rivPath, unsigned int width, unsigned int height);

    osg::ref_ptr<RenderDrawable> m_renderDrawable;
    osg::ref_ptr<osg::Geode> m_displayGeode;
    std::string m_rivPath;
    unsigned int m_width = 0;
    unsigned int m_height = 0;
    DrawMode m_drawMode = DrawMode::SCENE;
};

} // namespace osgRive
